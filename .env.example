# Strava API credentials
# Register your app at https://www.strava.com/settings/api
STRAVA_CLIENT_ID=your_client_id_here
STRAVA_CLIENT_SECRET=your_client_secret_here

# Your Strava Club ID
# Find it in the URL when viewing your club: strava.com/clubs/<CLUB_ID>
STRAVA_CLUB_ID=your_club_id_here

# OAuth tokens (populated automatically by scripts/authorize.py)
STRAVA_ACCESS_TOKEN=
STRAVA_REFRESH_TOKEN=
STRAVA_TOKEN_EXPIRES_AT=
